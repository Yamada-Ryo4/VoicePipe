<Window x:Class="VoicePipe.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VoicePipe.ViewModels"
        xmlns:ui="clr-namespace:VoicePipe.UI"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="VoicePipe" Height="900" Width="1250"
        MinHeight="680" MinWidth="900"
        Background="{DynamicResource BgDeepBrush}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- ContextMenu 挂在 Window 上才能在任何位置右键弹出 -->
    <Window.ContextMenu>
        <ContextMenu>
            <ContextMenu.Template>
                <ControlTemplate TargetType="ContextMenu">
                    <!-- 圆角 + 阴影的现代卡片样式，替代系统默认带槽的老式菜单 -->
                    <Border Background="{DynamicResource BgCardBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="4" SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="2" Opacity="0.5"/>
                        </Border.Effect>
                        <StackPanel IsItemsHost="True"/>
                    </Border>
                </ControlTemplate>
            </ContextMenu.Template>
            <MenuItem Click="OpenConsole_Click" Foreground="{DynamicResource TextPrimaryBrush}"
                      FontFamily="Segoe UI" FontSize="12.5">
                <MenuItem.Template>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="5" Padding="12,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🖥" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource StrOpenConsole}" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgPanelBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </MenuItem.Template>
            </MenuItem>
        </ContextMenu>
    </Window.ContextMenu>

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── 系统托盘图标（缩托盘后常驻，双击还原，右键菜单显示/退出）── -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="VoicePipe"
                        TrayMouseDoubleClick="Tray_Restore">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{DynamicResource StrTrayShow}" Click="Tray_Restore"/>
                    <MenuItem Header="{DynamicResource StrTrayExit}" Click="Tray_Exit"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- ══════════════ HEADER ══════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="28,18,28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">VoicePipe</TextBlock>
                        <TextBlock Text="v1.2.20" FontSize="11" Foreground="{DynamicResource TextSecBrush}"
                                   VerticalAlignment="Bottom" Margin="8,0,0,4"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource StrSubtitle}"
                               Foreground="{DynamicResource TextSecBrush}"
                               FontSize="11" Margin="0,3,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding IsCableAvailable, Converter={x:Static ui:BoolToColorConverter.Instance}}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock FontSize="11" Foreground="{DynamicResource TextSecBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="VB-Cable ✗"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCableAvailable}" Value="True">
                                        <Setter Property="Text" Value="VB-Cable ✓"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="2" CornerRadius="14"
                        BorderBrush="{DynamicResource TextSecBrush}" BorderThickness="1"
                        Background="{DynamicResource BgCardBrush}"
                        VerticalAlignment="Center" Margin="0,0,10,0" Cursor="Hand"
                        MouseLeftButtonUp="ToggleTheme_Click" Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ThemeIcon" Text="🌙" FontSize="13" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,4,0"/>
                        <TextBlock x:Name="ThemeLabel" Text="{DynamicResource StrThemeDark}" FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" CornerRadius="14"
                        BorderBrush="{DynamicResource TextSecBrush}" BorderThickness="1"
                        Background="{DynamicResource BgCardBrush}"
                        VerticalAlignment="Center" Margin="10,0,0,0" Cursor="Hand"
                        MouseLeftButtonUp="ToggleSettings_Click" Padding="10,6"
                        ToolTip="{DynamicResource StrSettings}">
                    <TextBlock x:Name="SettingsIcon" Text="⚙" FontSize="14" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════ MAIN CONTENT ══════════════ -->
        <!-- VerticalScrollBarVisibility=Visible：常显滚动条，使内容区宽度恒定。
             否则展开卡片导致内容变高、滚动条 Auto 出现时会让内容区缩 6px，所有滑块 thumb 跟着抖一下。 -->
        <ScrollViewer x:Name="MainContentView" Grid.Row="1" VerticalScrollBarVisibility="Visible" Padding="0,0,2,0"
                      RenderTransformOrigin="0.5,0.5">
            <ScrollViewer.RenderTransform>
                <TranslateTransform x:Name="MainContentTransform" X="0"/>
            </ScrollViewer.RenderTransform>
            <StackPanel Margin="24,20,24,20">

                <!-- ── App 音频源 ── -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,16" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource StrAppAudioSource}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <ComboBox ItemsSource="{Binding Processes}"
                                  SelectedItem="{Binding SelectedProcess}"
                                  Height="36" FontSize="12"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Background="{DynamicResource BgCardBrush}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,3" MinWidth="300">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="45"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{DynamicResource StrPid}" FontSize="10"
                                                       Foreground="{DynamicResource TextSecBrush}"
                                                       VerticalAlignment="Center" Margin="8,0,0,0"/>
                                            <TextBlock Text="{Binding Pid}" FontSize="10"
                                                       Foreground="{DynamicResource TextSecBrush}"
                                                       VerticalAlignment="Center" Margin="2,0,0,0"/>
                                        </StackPanel>
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                            <Rectangle Height="4" Fill="{DynamicResource BorderBrush}" RadiusX="2" RadiusY="2"/>
                                            <Rectangle Height="4" RadiusX="2" RadiusY="2"
                                                       HorizontalAlignment="Left"
                                                       Fill="{Binding PeakLevel, Converter={x:Static ui:PeakToClipBrushConverter.Instance}}">
                                                <Rectangle.Width>
                                                    <Binding Path="PeakLevel" Converter="{x:Static ui:PeakToWidthConverter.Instance}"
                                                             ConverterParameter="60"/>
                                                </Rectangle.Width>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding PeakLevel, StringFormat={}{0:P0}}"
                                                   Foreground="{DynamicResource TextSecBrush}"
                                                   FontSize="10" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- ── 麦克风输入 ── -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,16" Padding="20,16">
                    <StackPanel>
                        <!-- 标题行：左侧标题 / 右侧"停止保留直通"开关（与波形预览的频谱开关、降噪开关风格一致） -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource StrMicrophoneInput}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource StrMicPassthrough}"
                                       Foreground="{DynamicResource TextSecBrush}"
                                       FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                                       ToolTip="{DynamicResource StrMicPassthroughTooltip}"/>
                            <CheckBox Grid.Column="2" IsChecked="{Binding MicPassthrough, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      ToolTip="{DynamicResource StrMicPassthroughTooltip}"/>
                        </Grid>

                        <ComboBox ItemsSource="{Binding MicDevices}"
                                  SelectedItem="{Binding SelectedMic}"
                                  Height="36" FontSize="12"
                                  DropDownOpened="MicCombo_DropDownOpened"
                                  DropDownClosed="MicCombo_DropDownClosed"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Background="{DynamicResource BgCardBrush}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,3" MinWidth="300">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="45"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Grid Grid.Column="1" VerticalAlignment="Center" Margin="6,0">
                                            <Rectangle Height="4" Fill="{DynamicResource BorderBrush}" RadiusX="2" RadiusY="2"/>
                                            <Rectangle Height="4" RadiusX="2" RadiusY="2"
                                                       HorizontalAlignment="Left"
                                                       Fill="{Binding PeakLevel, Converter={x:Static ui:PeakToClipBrushConverter.Instance}}">
                                                <Rectangle.Width>
                                                    <Binding Path="PeakLevel" Converter="{x:Static ui:PeakToWidthConverter.Instance}"
                                                             ConverterParameter="60"/>
                                                </Rectangle.Width>
                                            </Rectangle>
                                        </Grid>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding PeakLevel, StringFormat={}{0:P0}}"
                                                   Foreground="{DynamicResource TextSecBrush}"
                                                   FontSize="10" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- ── 本地监听（从设置页迁移，可折叠）── -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,16" Padding="20,12">
                    <StackPanel>
                        <!-- 标题行：左侧三角 + 标题 + 右侧开关。整行可点击切换折叠 -->
                        <Grid Cursor="Hand" Background="Transparent"
                              MouseLeftButtonUp="ToggleMonitor_Click">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- 旋转三角：折叠 0°(▶) / 展开 90°(▼)，180ms EaseOut -->
                            <TextBlock Grid.Column="0" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource TextSecBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MonitorExpanded}" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="90"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0" To="90" Duration="0:0:0.18">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="90" To="0" Duration="0:0:0.18">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="1" Text="{DynamicResource StrMonitor}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="2" IsChecked="{Binding MonitorEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextSecBrush}"
                                      ToolTip="{DynamicResource StrMonitorEnable}"/>
                        </Grid>

                        <!-- 子内容：设备选择、音量、子开关、提示。折叠状态由 MonitorExpanded 控制（独立于功能开关），淡入 + 上滑 8px -->
                        <Grid Margin="0,12,0,0">
                            <Grid.RenderTransform>
                                <TranslateTransform Y="-8"/>
                            </Grid.RenderTransform>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding MonitorExpanded}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="1" Duration="0:0:0.20">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                         To="0" Duration="0:0:0.24">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0" Duration="0:0:0.14"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                         To="-8" Duration="0:0:0.14"/>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.14">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <StackPanel>
                                <!-- 监听输出设备选择 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource StrMonitorDevice}"
                                               VerticalAlignment="Center" FontSize="12" Margin="0,0,12,0"
                                               Foreground="{DynamicResource TextSecBrush}"/>
                                    <ComboBox Grid.Column="1" Height="30"
                                              ItemsSource="{Binding MonitorDevices}"
                                              SelectedItem="{Binding SelectedMonitorDevice, Mode=TwoWay}"
                                              DisplayMemberPath="Name"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              Background="{DynamicResource BgCardBrush}">
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Setter Property="Background" Value="{DynamicResource BgCardBrush}"/>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>
                                </Grid>
                                <!-- 监听音量 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource StrMonitorVolume}"
                                               VerticalAlignment="Center" FontSize="12" Margin="0,0,12,0"
                                               Foreground="{DynamicResource TextSecBrush}"/>
                                    <ui:SmoothSlider Grid.Column="1" Value="{Binding MonitorGain, Mode=TwoWay}"
                                            Minimum="0" Maximum="2" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding MonitorGain, StringFormat={}{0:P0}}"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                                </Grid>
                                <CheckBox IsChecked="{Binding MonitorApp, Mode=TwoWay}"
                                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8">
                                    <TextBlock Text="{DynamicResource StrMonitorApp}"/>
                                </CheckBox>
                                <CheckBox IsChecked="{Binding MonitorMic, Mode=TwoWay}"
                                          Foreground="{DynamicResource TextPrimaryBrush}">
                                    <TextBlock Text="{DynamicResource StrMonitorMic}"/>
                                </CheckBox>
                                <TextBlock Text="{DynamicResource StrMonitorHint}"
                                           Foreground="{DynamicResource TextSecBrush}"
                                           FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── 音量控制 ── -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,16" Padding="20,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource StrVolumeControl}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Text="↺" FontSize="14" Cursor="Hand"
                                       Foreground="{DynamicResource TextSecBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       ToolTip="Reset to default"
                                       MouseLeftButtonUp="ResetVolume_Click"/>
                        </Grid>

                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource StrAppAudio}"
                                       VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextSecBrush}"/>
                            <ui:SmoothSlider Grid.Column="1" Value="{Binding AppGain, Mode=TwoWay}"
                                    Minimum="0" Maximum="2" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding AppGain, StringFormat={}{0:P0}}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource StrMicrophone}"
                                       VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextSecBrush}"/>
                            <ui:SmoothSlider Grid.Column="1" Value="{Binding MicGain, Mode=TwoWay}"
                                    Minimum="0" Maximum="2" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding MicGain, StringFormat={}{0:P0}}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- ── 降噪（RNNoise 神经网络人声降噪，仅作用于麦克风路径，不影响 App 音频）── -->
                <!-- 主页位置：紧跟音量控制，便于用户在开始混音前/中临时调整 -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,16" Padding="20,12">
                    <StackPanel>
                        <Grid Cursor="Hand" Background="Transparent"
                              MouseLeftButtonUp="ToggleNoiseGate_Click">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- 旋转三角：折叠 0°(▶) / 展开 90°(▼)，180ms EaseOut -->
                            <TextBlock Grid.Column="0" Text="▶" FontSize="9"
                                       Foreground="{DynamicResource TextSecBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <RotateTransform Angle="0"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NoiseGateExpanded}" Value="True">
                                                <Setter Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="90"/>
                                                    </Setter.Value>
                                                </Setter>
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="0" To="90" Duration="0:0:0.18">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                             From="90" To="0" Duration="0:0:0.18">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.ExitActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="1" Text="{DynamicResource StrNoiseGate}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <CheckBox Grid.Column="2" IsChecked="{Binding NoiseGateEnabled, Mode=TwoWay}"
                                      Foreground="{DynamicResource TextSecBrush}"
                                      ToolTip="{DynamicResource StrNoiseGateTooltip}"/>
                        </Grid>

                        <!-- 强度滑块仅在降噪开启时显示，关闭时折叠节省空间。
                             v1.2.12: 用 DataTrigger 配 Storyboard 做淡入 + 上滑 8px 展开动画，
                             隐藏时先动画再设 Collapsed（避免动画被瞬间裁剪掉）。 -->
                        <Grid Margin="0,12,0,0">
                            <Grid.RenderTransform>
                                <TranslateTransform Y="-8"/>
                            </Grid.RenderTransform>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NoiseGateExpanded}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" Duration="0:0:0">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Visible}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="1" Duration="0:0:0.20">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                         To="0" Duration="0:0:0.24">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         To="0" Duration="0:0:0.14"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                         To="-8" Duration="0:0:0.14"/>
                                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Visibility" BeginTime="0:0:0.14">
                                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{x:Static Visibility.Collapsed}"/>
                                                        </ObjectAnimationUsingKeyFrames>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource StrDenoiseStrength}"
                                       VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource TextSecBrush}"/>
                            <ui:SmoothSlider Grid.Column="1" Value="{Binding DenoiseStrength, Mode=TwoWay}"
                                    Minimum="0" Maximum="1" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding DenoiseStrength, StringFormat={}{0:P0}}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── 波形预览（常显，无折叠）── -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,24" Padding="20,16">
                    <StackPanel>
                        <!-- 标题行：标题 + dB 文本 + 频谱开关（最右） -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource StrWaveformPreview}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <!-- dB 文本（开关左侧，固定宽度右对齐） -->
                            <TextBlock Grid.Column="1" Text="{Binding OutputPeakText}"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextSecBrush}"
                                       FontSize="12" FontFamily="Consolas" Margin="0,0,12,0"/>
                            <!-- 频谱开关（最右，与其它卡片统一） -->
                            <CheckBox Grid.Column="2" IsChecked="{Binding ShowSpectrum, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      Foreground="{DynamicResource TextSecBrush}"
                                      ToolTip="{DynamicResource StrSpectrumMode}"/>
                        </Grid>

                        <!-- 可视化区域：常显 -->
                        <Grid Height="72">
                            <ui:WaveformControl
                                WaveformData="{Binding WaveformData}"
                                Background="{DynamicResource BgCardBrush}"
                                LineBrush="{DynamicResource AccentBrush}"
                                Visibility="{Binding ShowSpectrum, Converter={x:Static ui:BoolToInvVisibilityConverter.Instance}}"/>
                            <ui:SpectrumControl
                                SpectrumData="{Binding SpectrumData}"
                                Background="{DynamicResource BgCardBrush}"
                                LineBrush="{DynamicResource AccentBrush}"
                                Visibility="{Binding ShowSpectrum, Converter={x:Static ui:BoolToVisibilityConverter.Instance}}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Content="{DynamicResource StrStartMixing}"
                            Style="{DynamicResource PrimaryButton}"
                            Command="{Binding StartPipelineCommand}"
                            Width="160" Height="44"
                            Visibility="{Binding IsRunning, Converter={x:Static ui:BoolToInvVisibilityConverter.Instance}}"/>

                    <Button Grid.Column="1"
                            Content="{DynamicResource StrStop}"
                            Style="{DynamicResource DangerButton}"
                            Command="{Binding StopPipelineCommand}"
                            Width="160" Height="44"
                            Visibility="{Binding IsRunning, Converter={x:Static ui:BoolToVisibilityConverter.Instance}}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════ SETTINGS VIEW (主页面内嵌) ══════════════ -->
        <ScrollViewer x:Name="SettingsView" Grid.Row="1" VerticalScrollBarVisibility="Visible" Padding="0,0,2,0"
                      Visibility="Collapsed"
                      RenderTransformOrigin="0.5,0.5">
            <ScrollViewer.RenderTransform>
                <TranslateTransform x:Name="SettingsTransform" X="0"/>
            </ScrollViewer.RenderTransform>
            <StackPanel Margin="24,20,24,20">

                <!-- 标题栏 + 返回 -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" CornerRadius="8" Cursor="Hand"
                            Background="{DynamicResource BgCardBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="10,5" VerticalAlignment="Center" Margin="0,0,12,0"
                            MouseLeftButtonUp="ToggleSettings_Click">
                        <TextBlock Text="←" FontSize="15" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="{DynamicResource StrSettingsTitle}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </Grid>

                <!-- 全局热键 -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,16" Padding="20,16">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource StrHotkeys}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Content="{DynamicResource StrHotkeyReset}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Style="{StaticResource GhostButton}"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Padding="10,3" FontSize="11"
                                    Click="ResetHotkeys_Click"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource StrHotkeyMuteMic}"
                                       Foreground="{DynamicResource TextSecBrush}"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ui:HotkeyCaptureControl Grid.Column="1" Height="32"
                                       Background="{DynamicResource BgCardBrush}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                       Binding="{Binding MuteHotkey, Mode=TwoWay}"
                                       HasConflict="{Binding MuteHotkeyConflict}"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{DynamicResource StrHotkeyTogglePipeline}"
                                       Foreground="{DynamicResource TextSecBrush}"
                                       VerticalAlignment="Center" FontSize="12"/>
                            <ui:HotkeyCaptureControl Grid.Column="1" Height="32"
                                       Background="{DynamicResource BgCardBrush}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                       Binding="{Binding PipelineHotkey, Mode=TwoWay}"
                                       HasConflict="{Binding PipelineHotkeyConflict}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 托盘 -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,16" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource StrTrayBehavior}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <CheckBox IsChecked="{Binding MinimizeToTray, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextPrimaryBrush}">
                            <TextBlock Text="{DynamicResource StrMinimizeToTray}"/>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- 降噪已迁到主页（v1.2.11）：用户使用流程在主页，临时调整不再要跑设置页。 -->
                <!-- 监听已迁到主页（v1.2.13）：跟降噪一样，使用流程在主页。 -->

                <!-- 自动启动 -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,24" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource StrAutoStart}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <CheckBox IsChecked="{Binding AutoStartBoot, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource StrAutoStartBoot}"/>
                        </CheckBox>
                        <CheckBox IsChecked="{Binding AutoStartPipelineSetting, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource StrAutoStartPipeline}"/>
                        </CheckBox>
                        <CheckBox IsChecked="{Binding StartMinimized, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12">
                            <TextBlock Text="{DynamicResource StrStartMinimized}"/>
                        </CheckBox>
                        <CheckBox IsChecked="{Binding AutoCheckUpdate, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextPrimaryBrush}">
                            <TextBlock Text="{DynamicResource StrAutoCheckUpdate}"/>
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!-- 语言 -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,24" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource StrLanguageTheme}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <ComboBox x:Name="LangSelector" Width="160" Height="32"
                                  HorizontalAlignment="Left"
                                  Foreground="{DynamicResource TextPrimaryBrush}"
                                  Background="{DynamicResource BgCardBrush}"
                                  SelectionChanged="Language_SelectionChanged">
                            <ComboBoxItem Content="简体中文" Tag="zh-CN"
                                Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource BgCardBrush}"/>
                            <ComboBoxItem Content="繁體中文" Tag="zh-TW"
                                Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource BgCardBrush}"/>
                            <ComboBoxItem Content="English" Tag="en-US"
                                Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource BgCardBrush}"/>
                            <ComboBoxItem Content="日本語" Tag="ja-JP"
                                Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource BgCardBrush}"/>
                            <ComboBoxItem Content="한국어" Tag="ko-KR"
                                Foreground="{DynamicResource TextPrimaryBrush}" Background="{DynamicResource BgCardBrush}"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <!-- 检查更新 / 关于 -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,24" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource StrUpdateSection}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{DynamicResource TextSecBrush}"
                                       Text="{Binding AppVersion, StringFormat=v{0}}"/>
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0"
                                       FontSize="12" TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource TextSecBrush}"
                                       Text="{Binding UpdateStatus}"/>
                            <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                    Padding="14,6" FontSize="12"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Content="{DynamicResource StrUpdateCheck}"
                                    Command="{Binding CheckUpdateCommand}"
                                    IsEnabled="{Binding IsCheckingUpdate, Converter={x:Static ui:BoolNegateConverter.Instance}}"/>
                        </Grid>
                        <!-- 下载进度条：仅下载时显示 -->
                        <Grid Margin="0,12,0,0"
                              Visibility="{Binding IsDownloading, Converter={x:Static ui:BoolToVisibilityConverter.Instance}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ProgressBar Grid.Column="0" Height="6" Minimum="0" Maximum="1"
                                         VerticalAlignment="Center"
                                         Value="{Binding DownloadProgress}"
                                         Background="{DynamicResource BgCardBrush}"
                                         Foreground="{DynamicResource AccentBrush}"
                                         BorderThickness="0"/>
                            <TextBlock Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center"
                                       FontSize="12" FontFamily="Consolas"
                                       Foreground="{DynamicResource TextSecBrush}"
                                       Text="{Binding DownloadPercentText}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 驱动检测与修复 -->
                <Border Background="{DynamicResource BgPanelBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8" Margin="0,0,0,24" Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource StrDriverSection}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="13" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush Color="{Binding IsCableAvailable, Converter={x:Static ui:BoolToColorConverter.Instance}}"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock FontSize="12" Foreground="{DynamicResource TextSecBrush}" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="VB-Cable ✗"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCableAvailable}" Value="True">
                                                    <Setter Property="Text" Value="VB-Cable ✓"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                    Padding="14,6" FontSize="12"
                                    Foreground="{DynamicResource TextPrimaryBrush}"
                                    Content="{DynamicResource StrDriverRepair}"
                                    Click="RepairVbCable_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════ STATUS BAR ══════════════ -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgDeepBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding IsRunning, Converter={x:Static ui:BoolToColorConverter.Instance}}"/>
                        </Ellipse.Fill>
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard x:Name="BlinkStoryboard">
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                        From="1.0" To="0.3" Duration="0:0:0.8"
                                                        AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="BlinkStoryboard"/>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                        To="1.0" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{DynamicResource TextSecBrush}"
                               FontSize="11.5" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="2"
                           Foreground="{DynamicResource TextSecBrush}"
                           FontSize="11" Opacity="0.8" VerticalAlignment="Center"
                           FontFamily="Segoe UI">
                    <Hyperlink NavigateUri="https://github.com/Yamada-Ryo4/VoicePipe"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               Foreground="{DynamicResource AccentBrush}"
                               TextDecorations="None">项目仓库 (GitHub)</Hyperlink>
                </TextBlock>
            </Grid>
        </Border>

        <!-- ══════════════ 首次使用引导（覆盖全窗口，仅首次启动显示）══════════════ -->
        <Border Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="100"
                Background="#CC000000"
                Visibility="{Binding ShowFirstRunGuide, Converter={x:Static ui:BoolToVisibilityConverter.Instance}}">
            <Border Background="{DynamicResource BgPanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="28,24" Width="440"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{DynamicResource StrGuideTitle}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="17" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource StrGuideSubtitle}"
                               Foreground="{DynamicResource TextSecBrush}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,0,0,18"/>

                    <!-- 步骤 1 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                            <TextBlock Text="1" Foreground="White" FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                   Text="{DynamicResource StrGuideStep1}"/>
                    </Grid>
                    <!-- 步骤 2 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                            <TextBlock Text="2" Foreground="White" FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                   Text="{DynamicResource StrGuideStep2}"/>
                    </Grid>
                    <!-- 步骤 3 -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11"
                                Background="{DynamicResource AccentBrush}" VerticalAlignment="Top">
                            <TextBlock Text="3" Foreground="White" FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="1" Margin="8,0,0,0" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                   Text="{DynamicResource StrGuideStep3}"/>
                    </Grid>

                    <Button HorizontalAlignment="Right" Style="{StaticResource PrimaryButton}"
                            Padding="20,8" FontSize="13"
                            Content="{DynamicResource StrGuideGotIt}"
                            Click="GuideGotIt_Click"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
